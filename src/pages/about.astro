---
import Base from "../layouts/Base.astro";

const GITHUB_URL = "https://github.com/alter-me-a-i";
const COFFEE_URL = "https://buymeacoffee.com/marcoajello";
const SUBSTACK_URL = "https://substack.com/@marcoajello";

const title = "About — alter/me/a/i";
const description =
  "Hey, I'm Marco. I build free, open-source tools for people who'd rather own their data than rent it back — plus two podcasts where I think out loud with an AI.";
---

<Base title={title} description={description}>
  <!-- ───────────────────────── NAV ───────────────────────── -->
  <header class="relative overflow-hidden">
    <div class="cortex-grid pointer-events-none absolute inset-0"></div>
    <div class="relative mx-auto max-w-5xl px-5 pt-8 sm:px-6 sm:pt-10">
      <nav class="flex items-center justify-between gap-3 font-mono text-sm">
        <a href="/" class="font-semibold tracking-tight transition hover:text-fg">
          marcoajello<span class="text-accent-2">.ai</span>
        </a>
        <div class="flex items-center gap-5 text-faint">
          <a href="/" class="hidden transition hover:text-fg sm:inline">home</a>
          <a href="/about" aria-current="page" class="text-fg">about</a>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="shrink-0 whitespace-nowrap rounded-full border border-accent-2/40 px-3 py-1.5 text-accent-2 transition hover:bg-accent-2/10">
            <span class="sm:hidden">source ↗</span>
            <span class="hidden sm:inline">view the source ↗</span>
          </a>
        </div>
      </nav>
    </div>

    <!-- ───────────────────────── INTRO ───────────────────────── -->
    <div class="relative mx-auto max-w-2xl px-5 pb-6 pt-16 sm:px-6 sm:pt-24">
      <p class="mb-6 inline-flex items-center rounded-full border border-border bg-surface/60 px-3 py-1 font-mono text-[11px] text-faint backdrop-blur-sm sm:text-xs">
        about
      </p>
      <h1 class="text-balance text-4xl font-bold leading-[1.08] tracking-tight sm:text-5xl">
        Hey, I'm Marco.
      </h1>
      <p class="mt-6 text-pretty text-lg leading-relaxed text-muted sm:text-xl">
        I build tools for people who'd rather <span class="text-fg">own their data</span>
        than keep renting it back from whoever's holding it.
      </p>
    </div>
  </header>

  <!-- ───────────────────────── BODY ───────────────────────── -->
  <main class="mx-auto max-w-2xl px-5 pb-16 sm:px-6 sm:pb-24">
    <div class="space-y-6 text-pretty text-base leading-relaxed text-muted sm:text-lg">
      <p>
        That's what
        <span class="whitespace-nowrap font-semibold text-fg">alter<span class="text-accent">/</span>me<span class="text-accent">/</span>a<span class="text-accent">/</span>i</span>
        is — a small, free, open-source suite of data-filtering extensions and apps
        that feed a <span class="text-fg">local-first encrypted Vault</span>. You decide
        what's kept and what's shared; the cortex sits in the middle, and
        <span class="text-fg">you hold the key. Nobody else.</span>
      </p>

      <p>
        I also make two podcasts —
        <a href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer" class="font-medium text-public underline decoration-public/40 underline-offset-2 transition hover:decoration-public">Listening to Myself</a>
        and
        <a href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer" class="font-medium text-private underline decoration-private/40 underline-offset-2 transition hover:decoration-private">Talking to Myself</a>
        — where I basically think out loud with an AI: working through real problems,
        and poking at neurodivergence, cognitive load (I call it "spoons"), and staying
        human while building alongside the machine.
      </p>

      <p>
        Everything I make is <span class="text-fg">free, ad-free, and open source.</span>
        If it's useful and you can spare it, buy me a coffee. ☕
      </p>
    </div>

    <!-- ───────────────────────── LINKS ───────────────────────── -->
    <div class="mt-10 flex flex-col items-stretch gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <a href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-surface/60 px-6 py-3 text-center font-medium text-fg backdrop-blur-sm transition hover:border-accent-2/50">
        The podcasts on Substack ↗
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-surface/60 px-6 py-3 text-center font-medium text-fg backdrop-blur-sm transition hover:border-accent-2/50">
        The code on GitHub ↗
      </a>
      <a href={COFFEE_URL} target="_blank" rel="noopener noreferrer" class="fill-primary rounded-full px-6 py-3 text-center font-semibold text-bg transition hover:opacity-90">
        ☕ Buy me a coffee ↗
      </a>
    </div>

    <p class="mt-10 font-mono text-xs text-faint">
      <a href="/" class="text-accent-2 underline-offset-2 hover:underline">← back to the hub</a>
    </p>
  </main>

  <!-- ───────────────────────── FOOTER ───────────────────────── -->
  <footer class="border-t border-border/60">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-5 px-5 py-10 text-center text-sm text-faint sm:flex-row sm:px-6 sm:text-left">
      <span class="font-mono">
        alter<span class="text-accent">/</span>me<span class="text-accent">/</span>a<span class="text-accent">/</span>i — hosted at marcoajello.ai
      </span>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-mono text-xs uppercase tracking-wide">
        <a href="/" class="transition hover:text-fg">marcoajello.ai <span class="text-faint">hub</span></a>
        <a href="https://my-alter.ai" target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">my-alter.ai <span class="text-faint">private</span></a>
        <a href="https://alter-me.ai" target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">alter-me.ai <span class="text-faint">learning</span></a>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">GitHub ↗</a>
        <a href={COFFEE_URL} target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">coffee ↗</a>
        <a href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">substack ↗</a>
      </div>
    </div>
  </footer>
</Base>
