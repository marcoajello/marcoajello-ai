---
import Base from "../layouts/Base.astro";
import HubDiagram from "../components/HubDiagram.astro";
import SpokeCard from "../components/SpokeCard.astro";

const spokes = [
  {
    vertex: "Personae / Vault",
    status: "built" as const,
    public: {
      name: "alter-me.ai",
      url: "https://alter-me.ai",
      blurb: "know thyself | own your self — the sociotype: the face you deploy outward, shaped by the membrane's rules.",
    },
    private: {
      name: "me-alter.ai",
      url: "https://me-alter.ai",
      blurb: "own your self | know thyself — the neurotype: the model-of-you, aggregated and interpreted on your terms.",
    },
  },
  {
    vertex: "Heuristics / Learning",
    status: "soon" as const,
    public: {
      name: "Listening to Myself",
      url: "https://marcoajello.substack.com",
      blurb: "problem-solving with AI — heuristics rendered out loud. On Substack for now; a paired domain later.",
    },
    private: {
      name: "Talking to Myself",
      blurb: "learning with AI — the private practice that feeds the public method. The holding side of the pair.",
    },
  },
  {
    vertex: "Gaming / Health",
    status: "concept" as const,
    public: {
      name: "the render",
      blurb: "the measurable-action axis, expressed — play, performance, the parts of doing you choose to show.",
    },
    private: {
      name: "the hold",
      blurb: "opt-in, disclosure-gated capture — steps, sleep, play data — high sensitivity, strict permission.",
    },
  },
];
---

<Base>
  <!-- ───────────────────────── HERO ───────────────────────── -->
  <header class="relative overflow-hidden">
    <div class="membrane-grid pointer-events-none absolute inset-0"></div>
    <div class="relative mx-auto max-w-5xl px-6 pt-10">
      <nav class="flex items-center justify-between font-mono text-sm">
        <span class="font-semibold tracking-tight">
          marcoajello<span class="text-accent-2">.ai</span>
        </span>
        <div class="flex items-center gap-5 text-faint">
          <a href="#fractal" class="transition hover:text-fg">architecture</a>
          <a href="#spokes" class="transition hover:text-fg">spokes</a>
          <a href="#extension" class="rounded-full border border-accent-2/40 px-3 py-1 text-accent-2 transition hover:bg-accent-2/10">get the extension</a>
        </div>
      </nav>
    </div>

    <div class="relative mx-auto max-w-4xl px-6 pb-12 pt-20 text-center sm:pt-28">
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-border bg-surface/60 px-3 py-1 font-mono text-xs text-faint backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-ok pulse-slow"></span>
        local-first · permission-gated · open source
      </p>

      <h1 class="text-balance text-5xl font-bold leading-[1.05] tracking-tight sm:text-7xl">
        Alter<span class="slash">/</span>Me<span class="slash">/</span>A<span class="slash">/</span>I
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-balance text-lg leading-relaxed text-muted sm:text-xl">
        The membrane at the center of your data. An open-source extension that
        sits between every input and every tool — it
        <span class="text-fg">encrypts your private side on-device</span>,
        mediates the public side, and lets
        <span class="text-fg">you decide what crosses, every time.</span>
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="#extension" class="rounded-full bg-accent-2 px-6 py-3 font-semibold text-bg transition hover:bg-public">
          Get the extension
        </a>
        <a href="#fractal" class="rounded-full border border-border bg-surface/60 px-6 py-3 font-medium text-fg backdrop-blur-sm transition hover:border-accent-2/50">
          See how it fits together
        </a>
      </div>

      <p class="mx-auto mt-10 max-w-xl font-mono text-xs leading-relaxed text-faint">
        The membrane is not a wall — it's a selectively-permeable gate with a
        doorman. Default-deny: nothing crosses inward to the interpreter, or
        outward to the world, except through an explicit, scoped, revocable
        permission.
      </p>
    </div>
  </header>

  <!-- ──────────────────── THE FRACTAL DIAGRAM ──────────────────── -->
  <section id="fractal" class="mx-auto max-w-5xl scroll-mt-12 px-6 py-16 sm:py-24">
    <div class="mb-10 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Hub and spokes, all the way down</h2>
      <p class="mx-auto mt-3 max-w-2xl text-muted">
        One hub is the only true infrastructure. Each spoke is a paired
        public / private vertex at a new domain of life — and the engine is the
        only thing that touches both sides. The pattern is fractal: new pairs
        extend it infinitely.
      </p>
    </div>

    <HubDiagram />

    <!-- the membrane → neurotype → sociotype model -->
    <div class="mx-auto mt-14 grid max-w-4xl gap-4 sm:grid-cols-3">
      <div class="rounded-2xl border border-accent-2/30 bg-surface/60 p-5">
        <div class="font-mono text-xs uppercase tracking-wide text-accent-2">the membrane</div>
        <div class="mt-1 font-semibold">Alter/Me/A/I</div>
        <p class="mt-2 text-sm text-muted">Regulates flux: capture gating, sensitivity classification, the permission gate. The only root of trust. Your raw exhaust stays on-device, behind it.</p>
      </div>
      <div class="rounded-2xl border border-private/30 bg-surface/60 p-5">
        <div class="font-mono text-xs uppercase tracking-wide text-private">the neurotype</div>
        <div class="mt-1 font-semibold">me-alter</div>
        <p class="mt-2 text-sm text-muted">Aggregates and interprets what the membrane lets through into the model-of-you. How you're actually wired — the private nucleus.</p>
      </div>
      <div class="rounded-2xl border border-public/30 bg-surface/60 p-5">
        <div class="font-mono text-xs uppercase tracking-wide text-public">the sociotype</div>
        <div class="mt-1 font-semibold">alter-me</div>
        <p class="mt-2 text-sm text-muted">The persona expressed outward — the socially-legible face, shaped by the membrane's rules. How the world reads you.</p>
      </div>
    </div>

    <p class="mx-auto mt-6 max-w-3xl text-center font-mono text-xs text-faint">
      glyph key — slash <span class="text-accent-2">/</span> = the cortex at the infrastructure layer (the hub) ·
      dash <span class="text-public">-</span> = the cortex at a user-facing surface (alter-me, me-alter)
    </p>
  </section>

  <!-- ──────────────────────── THE SPOKES ──────────────────────── -->
  <section id="spokes" class="mx-auto max-w-5xl scroll-mt-12 px-6 py-16 sm:py-20">
    <div class="mb-10">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">The spokes</h2>
      <p class="mt-3 max-w-2xl text-muted">
        Each vertex is the identical move at a new domain: one public-facing
        site that expresses, one private-facing site that holds — both passing
        through the membrane, which encrypts the private side and mediates the
        public one.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-1">
      {spokes.map((s) => <SpokeCard {...s} />)}
    </div>
  </section>

  <!-- ────────────────────── GET THE EXTENSION ────────────────────── -->
  <section id="extension" class="scroll-mt-12 px-6 py-16 sm:py-24">
    <div class="mx-auto max-w-3xl overflow-hidden rounded-3xl border border-accent-2/30 bg-gradient-to-b from-surface to-bg-2 p-8 text-center sm:p-12">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Get the membrane</h2>
      <p class="mx-auto mt-4 max-w-xl text-muted">
        Alter/Me/A/I is the open-source extension at the center of all of this.
        It runs locally, captures from the sources you choose, and never lets a
        byte cross a boundary without your say-so. Install it once; it mediates
        everything after.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="#" aria-disabled="true" class="rounded-full bg-accent-2 px-6 py-3 font-semibold text-bg transition hover:bg-public">
          Add to your browser
        </a>
        <a href="#" class="rounded-full border border-border bg-surface/60 px-6 py-3 font-medium text-fg transition hover:border-accent-2/50">
          View the source
        </a>
      </div>
      <p class="mt-5 font-mono text-xs text-faint">Distribution links land here when the extension ships. Local-first, zero-network, works offline.</p>
    </div>
  </section>

  <!-- ───────────────────────── FOOTER ───────────────────────── -->
  <footer class="border-t border-border/60">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-faint sm:flex-row">
      <span class="font-mono">
        Alter<span class="text-accent-2">/</span>Me<span class="text-accent-2">/</span>A<span class="text-accent-2">/</span>I — hosted at marcoajello.ai
      </span>
      <div class="flex items-center gap-5 font-mono">
        <a href="https://alter-me.ai" class="transition hover:text-public">alter-me.ai</a>
        <a href="https://me-alter.ai" class="transition hover:text-private">me-alter.ai</a>
        <a href="https://marcoajello.substack.com" class="transition hover:text-fg">substack</a>
      </div>
    </div>
  </footer>
</Base>
