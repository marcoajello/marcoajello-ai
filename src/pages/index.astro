---
import Base from "../layouts/Base.astro";
import HubDiagram from "../components/HubDiagram.astro";
import SpokeCard from "../components/SpokeCard.astro";

// The whole suite is free and open source. Canonical GitHub org is
// "alter-me-a-i" — the live org the websites deploy from. (Heads up: a few
// local repos still point at the older "me-alter" org; see the project notes.)
const GITHUB_URL = "https://github.com/alter-me-a-i";
const EXT_URL = "https://github.com/alter-me-a-i/alter-me-a-i"; // the extension
const VAULT_URL = "https://github.com/alter-me-a-i/vault";      // the encrypted Vault app
const COFFEE_URL = "https://buymeacoffee.com/marcoajello";

// Real download targets for the suite.
const CHROME_STORE_URL = "https://chromewebstore.google.com/detail/altermeai/oglkjafeedbmgogidpiffmghghjcpmlo";  // live on the Chrome Web Store
const EXT_ZIP_URL = "https://github.com/alter-me-a-i/alter-me/releases/latest";    // source / .zip build
const VAULT_DL_URL = "https://github.com/alter-me-a-i/vault/releases/download/v0.1.0/Vault-0.1.0-arm64.dmg";  // Vault for Mac (.dmg, one-click direct download)

// The three ecosystem sites, made clickable.
const PRIVATE_SITE = "https://my-alter.ai";   // the private side
const ENGINE_SITE = "https://marcoajello.ai"; // the cortex / hub
const LEARNING_SITE = "https://alter-me.ai";  // the learning side

const spokes = [
  {
    vertex: "Personae / Vault",
    status: "built" as const,
    public: {
      name: "Personae",
      url: "https://my-alter.ai",
      newTab: true,
      blurb: "Your public faces — curated, revocable exports of your Vault, shared on your terms. Minted on the private side.",
    },
    private: {
      name: "my-alter.ai",
      url: "https://my-alter.ai",
      newTab: true,
      blurb: "Your private self — the Vault and the software, kept on your machine. Only you hold the key.",
    },
  },
  {
    vertex: "Heuristics / Learning",
    status: "built" as const,
    public: {
      name: "Listening to Myself",
      url: "https://marcoajello.substack.com",
      newTab: true,
      blurb: "problem-solving with AI — heuristics rendered out loud.",
    },
    private: {
      name: "Talking to Myself",
      url: "https://marcoajello.substack.com",
      newTab: true,
      blurb: "learning with AI — the theory that feeds the method.",
    },
  },
  {
    vertex: "Gaming / Health",
    status: "concept" as const,
    public: {
      name: "the render",
      blurb: "the measurable-action axis, expressed — play, performance, the parts of doing you choose to show.",
    },
    private: {
      name: "the hold",
      blurb: "opt-in, disclosure-gated capture — steps, sleep, play data — high sensitivity, strict permission.",
    },
  },
];
---

<Base>
  <!-- ───────────────────────── HERO ───────────────────────── -->
  <header class="relative overflow-hidden">
    <div class="cortex-grid pointer-events-none absolute inset-0"></div>
    <div class="relative mx-auto max-w-5xl px-5 pt-8 sm:px-6 sm:pt-10">
      <nav class="flex items-center justify-between gap-3 font-mono text-sm">
        <span class="font-semibold tracking-tight">
          marcoajello<span class="text-accent-2">.ai</span>
        </span>
        <div class="flex items-center gap-5 text-faint">
          <a href="#architecture" class="hidden transition hover:text-fg sm:inline">architecture</a>
          <a href="#spokes" class="hidden transition hover:text-fg sm:inline">spokes</a>
          <a href="/about" class="transition hover:text-fg">about</a>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="shrink-0 whitespace-nowrap rounded-full border border-accent-2/40 px-3 py-1.5 text-accent-2 transition hover:bg-accent-2/10">
            <span class="sm:hidden">source ↗</span>
            <span class="hidden sm:inline">view the source ↗</span>
          </a>
        </div>
      </nav>
    </div>

    <div class="relative mx-auto max-w-4xl px-5 pb-12 pt-16 text-center sm:px-6 sm:pt-28">
      <p class="mb-6 inline-flex items-center rounded-full border border-ok/40 bg-ok/10 px-3 py-1 font-mono text-[11px] text-ok backdrop-blur-sm sm:text-xs">
        free &amp; open source · local-first · you own your data
      </p>

      <h1 class="wordmark font-bold">
        alter<span class="slash">/</span>me<span class="slash">/</span>a<span class="slash">/</span>i
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-pretty text-base leading-relaxed text-muted sm:text-xl">
        A <span class="text-fg font-semibold">suite</span> of lightweight,
        <span class="text-fg">data-filtering browser extensions and apps</span>
        that feed your <span class="text-fg">Vault</span> — a local-first,
        encrypted store you fully own. Together they form
        <span class="text-fg">the backbone of a complete personal
        data-aggregation system.</span>
      </p>

      <p class="mx-auto mt-5 max-w-2xl text-pretty text-base leading-relaxed text-fg sm:text-lg">
        <span class="text-accent font-semibold">The vision —</span> own your data,
        mine it into your own private AI, and license the personas you choose to
        share. Sovereign on your machine, never for sale; and one day, distributed
        compute so personal AI runs cheap on the people's hardware, not a data
        center's.
      </p>

      <div class="mx-auto mt-9 flex max-w-md flex-col items-stretch justify-center gap-3 sm:max-w-none sm:flex-row sm:flex-wrap sm:items-center">
        <a href="#architecture" class="rounded-full border border-border bg-surface/60 px-6 py-3 text-center font-medium text-fg backdrop-blur-sm transition hover:border-accent-2/50">
          See how it fits together
        </a>
        <a href={PRIVATE_SITE} target="_blank" rel="noopener noreferrer" class="fill-primary rounded-full px-6 py-3 text-center font-semibold text-bg transition hover:opacity-90">
          Get the extension ↗
        </a>
        <a href={COFFEE_URL} target="_blank" rel="noopener noreferrer" class="rounded-full border border-border bg-surface/60 px-6 py-3 text-center font-medium text-fg backdrop-blur-sm transition hover:border-accent-2/50">
          ☕ Buy me a coffee
        </a>
      </div>

      <p class="mx-auto mt-6 max-w-md text-pretty font-mono text-xs leading-relaxed text-faint">
        100% free and open source — every extension, the Vault, and the cortex.
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="break-token text-accent-2 underline-offset-2 hover:underline">github.com/alter-me-a-i ↗</a>
      </p>

      <p class="mx-auto mt-10 max-w-xl text-pretty font-mono text-xs leading-relaxed text-faint">
        Nothing reaches the Vault, and nothing leaves it, without your explicit
        OK — for what, for how long, and revocable any time.
      </p>
    </div>
  </header>

  <!-- ──────────────────── THE FRACTAL DIAGRAM ──────────────────── -->
  <section id="architecture" class="mx-auto max-w-5xl scroll-mt-12 px-5 py-14 sm:px-6 sm:py-24">
    <div class="mb-10 text-center">
      <h2 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl">One hub, two sides per area of life</h2>
      <p class="mx-auto mt-3 max-w-2xl text-pretty text-muted">
        For each area of life there's a public side that shows and a private
        side that holds — and the cortex is the only thing that touches both.
        Add a new pair whenever life adds an area.
      </p>
    </div>

    <HubDiagram />

    <!-- the two sides, with the cortex between them -->
    <div class="mx-auto mt-12 grid max-w-4xl gap-4 sm:mt-14 sm:grid-cols-3">
      <a href={PRIVATE_SITE} target="_blank" rel="noopener noreferrer" class="group block cursor-pointer rounded-2xl border border-private/30 bg-surface/60 p-5 transition hover:border-private/70 hover:bg-surface">
        <div class="font-mono text-xs uppercase tracking-wide text-private">the private side</div>
        <div class="mt-1 font-semibold text-accent group-hover:underline underline-offset-2">my-alter.ai ↗</div>
        <p class="mt-2 text-sm text-muted">Privacy and the software: the extension, the setup wizard, and your encrypted Vault. It lives on your machine, and only you hold the key.</p>
      </a>
      <a href={ENGINE_SITE} target="_blank" rel="noopener noreferrer" class="group block cursor-pointer rounded-2xl border border-accent-2/30 bg-surface/60 p-5 transition hover:border-accent-2/70 hover:bg-surface">
        <div class="font-mono text-xs uppercase tracking-wide text-accent">the cortex</div>
        <div class="mt-1 font-semibold text-accent group-hover:underline underline-offset-2">alter/me/a/i ↗</div>
        <p class="mt-2 text-sm text-muted">The cortex in the middle. It decides what gets captured and what reaches your Vault. Your raw data never leaves your device.</p>
      </a>
      <a href={LEARNING_SITE} target="_blank" rel="noopener noreferrer" class="group block cursor-pointer rounded-2xl border border-public/30 bg-surface/60 p-5 transition hover:border-public/70 hover:bg-surface">
        <div class="font-mono text-xs uppercase tracking-wide text-public">the learning side</div>
        <div class="mt-1 font-semibold text-accent group-hover:underline underline-offset-2">alter-me.ai ↗</div>
        <p class="mt-2 text-sm text-muted">The ideas out loud: the heuristics, the white papers, and the philosophy behind the tools — the part you can learn from and share.</p>
      </a>
    </div>

  </section>

  <!-- ──────────────────────── THE SPOKES ──────────────────────── -->
  <section id="spokes" class="mx-auto max-w-5xl scroll-mt-12 px-5 py-14 sm:px-6 sm:py-20">
    <div class="mb-8 sm:mb-10">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">The spokes</h2>
      <p class="mt-3 max-w-2xl text-pretty text-muted">
        Same idea every time: one public site that shows, one private site that
        holds. The cortex sits between them — it encrypts the private side and
        you control the public one.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-1">
      {spokes.map((s) => <SpokeCard {...s} />)}
    </div>
  </section>

  <!-- ────────────────────── GET THE EXTENSION ────────────────────── -->
  <section id="extension" class="scroll-mt-12 px-5 py-14 sm:px-6 sm:py-24">
    <div class="mx-auto max-w-3xl overflow-hidden rounded-3xl border border-accent-2/30 bg-gradient-to-b from-surface to-bg-2 p-6 text-center sm:p-12">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-ok/40 bg-ok/10 px-3 py-1 font-mono text-xs text-ok">
        <span class="h-1.5 w-1.5 rounded-full bg-ok"></span>
        Free and open source
      </p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Get the software</h2>

      <!-- Primary downloads up top: one click to install. -->
      <div class="mx-auto mt-6 flex max-w-2xl flex-col items-stretch justify-center gap-3 sm:flex-row sm:flex-wrap sm:items-center">
        <a href={CHROME_STORE_URL} target="_blank" rel="noopener noreferrer" class="fill-primary inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-semibold text-bg transition hover:opacity-90">
          Add to Chrome ↗
        </a>
        <a href={EXT_ZIP_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-surface/60 px-6 py-3 font-medium text-fg transition hover:border-accent-2/50">
          Download .zip
        </a>
        <a href={VAULT_DL_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-surface/60 px-6 py-3 font-medium text-fg transition hover:border-accent-2/50">
          Download Vault for Mac
        </a>
      </div>

      <p class="mx-auto mt-5 max-w-xl text-pretty text-muted">
        Everything's free and open source — the extension, the cortex, and the
        Vault. Prefer to build it yourself? Clone either repo from GitHub and run
        it on your own machine.
      </p>

      <!-- The two pieces of software: download first, clone if you'd rather. -->
      <div class="mx-auto mt-8 grid max-w-2xl gap-4 text-left sm:grid-cols-2">
        <div class="rounded-2xl border border-border bg-bg-2/40 p-5">
          <div class="font-semibold">The extension <span class="font-normal text-faint">— alter/me/a/i</span></div>
          <p class="mt-2 text-sm text-muted">Add it from the Chrome Web Store, or grab the store-ready .zip and load it unpacked (Developer mode → Load unpacked → pick the folder).</p>
          <div class="mt-3 flex flex-wrap gap-3">
            <a href={CHROME_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block font-mono text-xs text-accent-2 underline-offset-2 hover:underline">Add to Chrome ↗</a>
            <a href={EXT_ZIP_URL} target="_blank" rel="noopener noreferrer" class="inline-block font-mono text-xs text-accent-2 underline-offset-2 hover:underline">Download .zip ↗</a>
          </div>
          <a href={EXT_URL} target="_blank" rel="noopener noreferrer" class="mt-2 inline-block font-mono text-xs text-faint underline-offset-2 hover:underline hover:text-accent-2">source on GitHub ↗</a>
        </div>
        <div class="rounded-2xl border border-border bg-bg-2/40 p-5">
          <div class="font-semibold">The Vault app <span class="font-normal text-faint">— your encrypted store</span></div>
          <p class="mt-2 text-sm text-muted">Download the Mac build and set your master password, or clone the repo and build it yourself from the README.</p>
          <a href={VAULT_DL_URL} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block font-mono text-xs text-accent-2 underline-offset-2 hover:underline">Download for Mac ↗</a>
          <a href={VAULT_URL} target="_blank" rel="noopener noreferrer" class="mt-2 block font-mono text-xs text-faint underline-offset-2 hover:underline hover:text-accent-2">source on GitHub ↗</a>
        </div>
      </div>

      <div class="mx-auto mt-7 flex max-w-md flex-col items-stretch justify-center gap-3 sm:max-w-none sm:flex-row sm:flex-wrap sm:items-center">
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="fill-primary inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-semibold text-bg transition hover:opacity-90"
        >
          All the source on GitHub ↗
        </a>
        <a
          href={COFFEE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-border bg-surface/60 px-6 py-3 font-medium text-fg transition hover:border-accent-2/50"
        >
          ☕ Buy me a coffee
        </a>
      </div>
      <p class="mx-auto mt-5 max-w-md text-pretty font-mono text-xs leading-relaxed text-faint">Local-first, zero-network, works offline.</p>
    </div>
  </section>

  <!-- ───────────────────────── FOOTER ───────────────────────── -->
  <footer class="border-t border-border/60">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-5 px-5 py-10 text-center text-sm text-faint sm:flex-row sm:px-6 sm:text-left">
      <span class="font-mono">
        alter<span class="text-accent">/</span>me<span class="text-accent">/</span>a<span class="text-accent">/</span>i — hosted at marcoajello.ai
      </span>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-mono text-xs uppercase tracking-wide">
        <span class="text-fg/80">marcoajello.ai <span class="text-faint">hub</span></span>
        <a href="https://my-alter.ai" target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">my-alter.ai <span class="text-faint">private</span></a>
        <a href="https://alter-me.ai" target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">alter-me.ai <span class="text-faint">learning</span></a>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">GitHub ↗</a>
        <a href="https://buymeacoffee.com/marcoajello" target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">coffee ↗</a>
        <a href="https://substack.com/@marcoajello" target="_blank" rel="noopener noreferrer" class="transition hover:text-fg">substack ↗</a>
      </div>
    </div>
  </footer>
</Base>
