---
/*
  Hub-and-spokes as a self-similar Y-fractal with the cortex in the MIDDLE.

  • The cortex (alter/me/a/i) sits at the vertical centre of the canvas.
  • THREE spokes leave it, ALL in the cortex's pink (accent-2):
      ── two SOLID arms UP, forming a Y, to the two real vertices:
           up-left  → Heuristics / Learning   (in progress)
           up-right → Personae / Vault         (live)
      ── one DOTTED arm straight DOWN to Gaming / Health (planned), which keeps
         forking the same Y in progressively fainter dotted branches — growth
         fading downward into infinity.
  • Each UP vertex forks the identical Y into a public (warm, left) and private
    (cool, right) leaf, drawn SOLID — these are built / in progress.
  • Gaming forks the same way into render (public) / hold (private), but
    dotted + faded, because downward is the unbuilt growth direction.

  Two renderings of the one rule: a wide version ≥sm, a tall narrow one <sm.
*/
type Status = "built" | "soon" | "concept";
type Vertex = { label: string; status: Status; public: string; private: string };

const personae: Vertex = { label: "Personae / Vault", status: "built", public: "alter-me", private: "my-alter" };
const heuristics: Vertex = { label: "Heuristics / Learning", status: "soon", public: "listening", private: "talking" };
const gaming: Vertex = { label: "Gaming / Health", status: "concept", public: "render", private: "hold" };

const PINK = "var(--color-accent-2)";
const SOLID = "0";
const DOTS = "2 7"; // round-capped dots — the "growth / not-yet-built" texture

const statusColor: Record<Status, string> = {
  built: "var(--color-accent-2)",
  soon: "var(--color-faint)",
  concept: "var(--color-border)",
};
const statusLabel: Record<Status, string> = { built: "live", soon: "in progress", concept: "planned" };

// ── The universal fork: 30° off vertical, each level 0.6× the last. ──
const FORK_DEG = 30;
const SIN = Math.sin((FORK_DEG * Math.PI) / 180); // 0.5
const COS = Math.cos((FORK_DEG * Math.PI) / 180); // 0.866…
const RATIO = 0.6;

type Seg = { x1: number; y1: number; x2: number; y2: number; w: number; o: number };

// A point reached by forking from (x,y): signX = -1 left / +1 right, dir = -1 up / +1 down.
const armPt = (x: number, y: number, len: number, signX: -1 | 1, dir: -1 | 1) => ({
  x: x + signX * len * SIN,
  y: y + dir * len * COS,
});

// The faded, unlabelled continuation of the SAME Y, scaled down each level.
function fadedTree(x: number, y: number, len: number, dir: -1 | 1, depth: number, level = 0): Seg[] {
  if (depth <= 0) return [];
  const l = armPt(x, y, len, -1, dir);
  const r = armPt(x, y, len, 1, dir);
  const w = Math.max(0.7, 1.5 * Math.pow(RATIO, level));
  const o = 0.32 * Math.pow(0.58, level);
  return [
    { x1: x, y1: y, x2: l.x, y2: l.y, w, o },
    { x1: x, y1: y, x2: r.x, y2: r.y, w, o },
    ...fadedTree(l.x, l.y, len * RATIO, dir, depth - 1, level + 1),
    ...fadedTree(r.x, r.y, len * RATIO, dir, depth - 1, level + 1),
  ];
}

// Build an upward vertex (cortex → up to vertex → forks up into public/private leaves).
function upVertex(v: Vertex, side: -1 | 1, cx: number, cy: number, LV: number, LB: number) {
  const vx = cx + side * LV * SIN;
  const vy = cy - LV * COS;
  return { v, side, vx, vy, pub: armPt(vx, vy, LB, -1, -1), priv: armPt(vx, vy, LB, 1, -1) };
}
// Build the downward vertex (cortex → straight down → forks down, then fades to infinity).
function downVertex(v: Vertex, cx: number, cy: number, LV: number, LB: number, depth: number) {
  const vx = cx;
  const vy = cy + LV;
  const pub = armPt(vx, vy, LB, -1, 1);
  const priv = armPt(vx, vy, LB, 1, 1);
  const faded = [
    ...fadedTree(pub.x, pub.y, LB * RATIO, 1, depth),
    ...fadedTree(priv.x, priv.y, LB * RATIO, 1, depth),
  ];
  return { v, vx, vy, pub, priv, faded };
}

// ───────────── Desktop / tablet: cortex centred, Y up, fade down ─────────────
const DW = 940;
const DH = 760;
const dcx = DW / 2;
const dcy = 384;
const D_LVu = 188; // cortex → up vertex
const D_LBu = 96; // up vertex → leaf
const D_LVd = 176; // cortex → down vertex
const D_LBd = 92; // down vertex → leaf
const D_FADE = 3;

const dHeur = upVertex(heuristics, -1, dcx, dcy, D_LVu, D_LBu); // up-left
const dPers = upVertex(personae, 1, dcx, dcy, D_LVu, D_LBu); // up-right
const dGame = downVertex(gaming, dcx, dcy, D_LVd, D_LBd, D_FADE); // down
const dUp = [dHeur, dPers];

// ───────────── Mobile: same idea, narrow + tall ─────────────
const MW = 380;
const MH = 540;
const mcx = MW / 2;
const mcy = 260;
const M_LVu = 132;
const M_LBu = 66;
const M_LVd = 120;
const M_LBd = 66;
const M_FADE = 3;

const mHeur = upVertex(heuristics, -1, mcx, mcy, M_LVu, M_LBu);
const mPers = upVertex(personae, 1, mcx, mcy, M_LVu, M_LBu);
const mGame = downVertex(gaming, mcx, mcy, M_LVd, M_LBd, M_FADE);
const mUp = [mHeur, mPers];
---

<figure
  class="mx-auto w-full max-w-3xl"
  aria-label="alter/me/a/i (the cortex) sits at the centre. Three pink spokes leave it: two solid arms up form a Y to the built vertices Personae / Vault (live) and Heuristics / Learning (in progress), each forking into a public and a private leaf; one dotted arm goes down to the planned Gaming / Health vertex and keeps forking into ever-fainter dotted branches — growth fading downward into infinity."
>
  {/* ════════ MOBILE (<sm) ════════ */}
  <svg viewBox={`0 0 ${MW} ${MH}`} class="block h-auto w-full sm:hidden" role="img">
    <defs>
      <radialGradient id="coreGlowM" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#ff6b81" stop-opacity="0.9"></stop>
        <stop offset="55%" stop-color="#c1364a" stop-opacity="0.85"></stop>
        <stop offset="100%" stop-color="#2b1055" stop-opacity="0.95"></stop>
      </radialGradient>
      <filter id="softM" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6"></feGaussianBlur>
      </filter>
    </defs>

    {/* faded growth, fading downward (behind everything) */}
    {mGame.faded.map((s) => (
      <line x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke="var(--color-faint)" stroke-width={s.w} stroke-linecap="round" stroke-dasharray={DOTS} opacity={s.o}></line>
    ))}

    {/* the three center spokes — ALL pink; two solid up, one dotted down */}
    <line x1={mcx} y1={mcy} x2={mHeur.vx} y2={mHeur.vy} stroke={PINK} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={SOLID} opacity="0.95"></line>
    <line x1={mcx} y1={mcy} x2={mPers.vx} y2={mPers.vy} stroke={PINK} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={SOLID} opacity="0.95"></line>
    <line x1={mcx} y1={mcy} x2={mGame.vx} y2={mGame.vy} stroke={PINK} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={DOTS} opacity="0.7"></line>

    {/* upward vertices: solid Y into public (left) / private (right) leaves */}
    {mUp.map((d) => {
      const c = statusColor[d.v.status];
      const anchor = d.side < 0 ? "end" : "start";
      const lx = d.vx + d.side * 13;
      return (
        <g>
          <line x1={d.vx} y1={d.vy} x2={d.pub.x} y2={d.pub.y} stroke="var(--color-public)" stroke-width="2" stroke-linecap="round" opacity="0.95"></line>
          <line x1={d.vx} y1={d.vy} x2={d.priv.x} y2={d.priv.y} stroke="var(--color-private)" stroke-width="2" stroke-linecap="round" opacity="0.95"></line>

          {/* public leaf */}
          <circle cx={d.pub.x} cy={d.pub.y} r="5.5" fill="var(--color-public)"></circle>
          <text x={d.pub.x} y={d.pub.y - 20} text-anchor="middle" fill="var(--color-public)" font-family="var(--font-mono)" font-size="12" font-weight="600">{d.v.public}</text>
          <text x={d.pub.x} y={d.pub.y - 9} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="8.5">public</text>
          {/* private leaf */}
          <circle cx={d.priv.x} cy={d.priv.y} r="5.5" fill="var(--color-private)"></circle>
          <text x={d.priv.x} y={d.priv.y - 20} text-anchor="middle" fill="var(--color-private)" font-family="var(--font-mono)" font-size="12" font-weight="600">{d.v.private}</text>
          <text x={d.priv.x} y={d.priv.y - 9} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="8.5">private</text>

          {/* vertex node + label on the outer side */}
          <circle cx={d.vx} cy={d.vy} r="6" fill="var(--color-surface-2)" stroke={c} stroke-width="2"></circle>
          <text x={lx} y={d.vy + 1} text-anchor={anchor} fill="var(--color-fg)" font-family="var(--font-sans)" font-size="11" font-weight="600">{d.v.label}</text>
          <text x={lx} y={d.vy + 13} text-anchor={anchor} fill={c} font-family="var(--font-mono)" font-size="8.5" letter-spacing="0.05em">{statusLabel[d.v.status].toUpperCase()}</text>
        </g>
      );
    })}

    {/* downward vertex: dotted/faded Y into render / hold, then fading onward */}
    <g>
      <line x1={mGame.vx} y1={mGame.vy} x2={mGame.pub.x} y2={mGame.pub.y} stroke="var(--color-public)" stroke-width="2" stroke-linecap="round" stroke-dasharray={DOTS} opacity="0.6"></line>
      <line x1={mGame.vx} y1={mGame.vy} x2={mGame.priv.x} y2={mGame.priv.y} stroke="var(--color-private)" stroke-width="2" stroke-linecap="round" stroke-dasharray={DOTS} opacity="0.6"></line>

      <circle cx={mGame.pub.x} cy={mGame.pub.y} r="5" fill="var(--color-public)" opacity="0.85"></circle>
      <text x={mGame.pub.x} y={mGame.pub.y + 16} text-anchor="middle" fill="var(--color-public)" font-family="var(--font-mono)" font-size="11.5" font-weight="600" opacity="0.9">{gaming.public}</text>
      <text x={mGame.pub.x} y={mGame.pub.y + 27} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="8.5">public</text>
      <circle cx={mGame.priv.x} cy={mGame.priv.y} r="5" fill="var(--color-private)" opacity="0.85"></circle>
      <text x={mGame.priv.x} y={mGame.priv.y + 16} text-anchor="middle" fill="var(--color-private)" font-family="var(--font-mono)" font-size="11.5" font-weight="600" opacity="0.9">{gaming.private}</text>
      <text x={mGame.priv.x} y={mGame.priv.y + 27} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="8.5">private</text>

      <circle cx={mGame.vx} cy={mGame.vy} r="6" fill="var(--color-surface-2)" stroke={statusColor[gaming.status]} stroke-width="2"></circle>
      <text x={mGame.vx + 13} y={mGame.vy + 1} text-anchor="start" fill="var(--color-fg)" font-family="var(--font-sans)" font-size="11" font-weight="600">{gaming.label}</text>
      <text x={mGame.vx + 13} y={mGame.vy + 13} text-anchor="start" fill={statusColor[gaming.status]} font-family="var(--font-mono)" font-size="8.5" letter-spacing="0.05em">{statusLabel[gaming.status].toUpperCase()}</text>
    </g>

    {/* the cortex, glowing, at the centre */}
    <circle cx={mcx} cy={mcy} r="42" fill="url(#coreGlowM)" filter="url(#softM)" opacity="0.55" class="pulse-slow"></circle>
    <circle cx={mcx} cy={mcy} r="34" fill="var(--color-bg-2)" stroke="var(--color-accent-2)" stroke-width="2"></circle>
    <text x={mcx} y={mcy - 2} text-anchor="middle" fill="var(--color-fg)" font-family="var(--font-sans)" font-size="14" font-weight="700">alter<tspan fill="var(--color-accent-2)">/</tspan>me<tspan fill="var(--color-accent-2)">/</tspan>a<tspan fill="var(--color-accent-2)">/</tspan>i</text>
    <text x={mcx} y={mcy + 13} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="9.5">the cortex</text>
  </svg>

  {/* ════════ DESKTOP / TABLET (≥sm) ════════ */}
  <svg viewBox={`0 0 ${DW} ${DH}`} class="hidden h-auto w-full sm:block" role="img">
    <defs>
      <radialGradient id="coreGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#ff6b81" stop-opacity="0.9"></stop>
        <stop offset="55%" stop-color="#c1364a" stop-opacity="0.85"></stop>
        <stop offset="100%" stop-color="#2b1055" stop-opacity="0.95"></stop>
      </radialGradient>
      <filter id="soft" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6"></feGaussianBlur>
      </filter>
    </defs>

    {/* faded growth, fading downward into infinity (behind everything) */}
    {dGame.faded.map((s) => (
      <line x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke="var(--color-faint)" stroke-width={s.w} stroke-linecap="round" stroke-dasharray={DOTS} opacity={s.o}></line>
    ))}

    {/* the three center spokes — ALL pink; two solid up (the Y), one dotted down */}
    <line x1={dcx} y1={dcy} x2={dHeur.vx} y2={dHeur.vy} stroke={PINK} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={SOLID} opacity="0.95"></line>
    <line x1={dcx} y1={dcy} x2={dPers.vx} y2={dPers.vy} stroke={PINK} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={SOLID} opacity="0.95"></line>
    <line x1={dcx} y1={dcy} x2={dGame.vx} y2={dGame.vy} stroke={PINK} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={DOTS} opacity="0.7"></line>

    {/* upward vertices: solid Y into public (left) / private (right) leaves */}
    {dUp.map((d) => {
      const c = statusColor[d.v.status];
      const anchor = d.side < 0 ? "end" : "start";
      const lx = d.vx + d.side * 14;
      return (
        <g>
          <line x1={d.vx} y1={d.vy} x2={d.pub.x} y2={d.pub.y} stroke="var(--color-public)" stroke-width="2.25" stroke-linecap="round" opacity="0.95"></line>
          <line x1={d.vx} y1={d.vy} x2={d.priv.x} y2={d.priv.y} stroke="var(--color-private)" stroke-width="2.25" stroke-linecap="round" opacity="0.95"></line>

          {/* public leaf */}
          <circle cx={d.pub.x} cy={d.pub.y} r="6" fill="var(--color-public)"></circle>
          <text x={d.pub.x} y={d.pub.y - 22} text-anchor="middle" fill="var(--color-public)" font-family="var(--font-mono)" font-size="13" font-weight="600">{d.v.public}</text>
          <text x={d.pub.x} y={d.pub.y - 9} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="9.5">public</text>
          {/* private leaf */}
          <circle cx={d.priv.x} cy={d.priv.y} r="6" fill="var(--color-private)"></circle>
          <text x={d.priv.x} y={d.priv.y - 22} text-anchor="middle" fill="var(--color-private)" font-family="var(--font-mono)" font-size="13" font-weight="600">{d.v.private}</text>
          <text x={d.priv.x} y={d.priv.y - 9} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="9.5">private</text>

          {/* vertex node + label on the outer side (clear of the spokes) */}
          <circle cx={d.vx} cy={d.vy} r="7" fill="var(--color-surface-2)" stroke={c} stroke-width="2"></circle>
          <text x={lx} y={d.vy + 1} text-anchor={anchor} fill="var(--color-fg)" font-family="var(--font-sans)" font-size="14" font-weight="600">{d.v.label}</text>
          <text x={lx} y={d.vy + 15} text-anchor={anchor} fill={c} font-family="var(--font-mono)" font-size="10" letter-spacing="0.05em">{statusLabel[d.v.status].toUpperCase()}</text>
        </g>
      );
    })}

    {/* downward vertex: dotted/faded Y into render / hold (the growth direction) */}
    <g>
      <line x1={dGame.vx} y1={dGame.vy} x2={dGame.pub.x} y2={dGame.pub.y} stroke="var(--color-public)" stroke-width="2.25" stroke-linecap="round" stroke-dasharray={DOTS} opacity="0.6"></line>
      <line x1={dGame.vx} y1={dGame.vy} x2={dGame.priv.x} y2={dGame.priv.y} stroke="var(--color-private)" stroke-width="2.25" stroke-linecap="round" stroke-dasharray={DOTS} opacity="0.6"></line>

      <circle cx={dGame.pub.x} cy={dGame.pub.y} r="5.5" fill="var(--color-public)" opacity="0.85"></circle>
      <text x={dGame.pub.x} y={dGame.pub.y + 18} text-anchor="middle" fill="var(--color-public)" font-family="var(--font-mono)" font-size="12.5" font-weight="600" opacity="0.9">{gaming.public}</text>
      <text x={dGame.pub.x} y={dGame.pub.y + 30} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="9.5">public</text>
      <circle cx={dGame.priv.x} cy={dGame.priv.y} r="5.5" fill="var(--color-private)" opacity="0.85"></circle>
      <text x={dGame.priv.x} y={dGame.priv.y + 18} text-anchor="middle" fill="var(--color-private)" font-family="var(--font-mono)" font-size="12.5" font-weight="600" opacity="0.9">{gaming.private}</text>
      <text x={dGame.priv.x} y={dGame.priv.y + 30} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="9.5">private</text>

      <circle cx={dGame.vx} cy={dGame.vy} r="7" fill="var(--color-surface-2)" stroke={statusColor[gaming.status]} stroke-width="2"></circle>
      <text x={dGame.vx + 14} y={dGame.vy + 1} text-anchor="start" fill="var(--color-fg)" font-family="var(--font-sans)" font-size="14" font-weight="600">{gaming.label}</text>
      <text x={dGame.vx + 14} y={dGame.vy + 15} text-anchor="start" fill={statusColor[gaming.status]} font-family="var(--font-mono)" font-size="10" letter-spacing="0.05em">{statusLabel[gaming.status].toUpperCase()}</text>
    </g>

    {/* the cortex, glowing, at the centre */}
    <circle cx={dcx} cy={dcy} r="62" fill="url(#coreGlow)" filter="url(#soft)" opacity="0.55" class="pulse-slow"></circle>
    <circle cx={dcx} cy={dcy} r="45" fill="var(--color-bg-2)" stroke="var(--color-accent-2)" stroke-width="2"></circle>
    <text x={dcx} y={dcy - 4} text-anchor="middle" fill="var(--color-fg)" font-family="var(--font-sans)" font-size="16" font-weight="700">alter<tspan fill="var(--color-accent-2)">/</tspan>me<tspan fill="var(--color-accent-2)">/</tspan>a<tspan fill="var(--color-accent-2)">/</tspan>i</text>
    <text x={dcx} y={dcy + 15} text-anchor="middle" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="10.5">the cortex</text>
  </svg>

  <figcaption class="mt-5 text-center font-mono text-xs leading-relaxed text-faint">
    the cortex at the centre · <span class="text-accent-2">pink spokes</span> out to every vertex ·
    <span class="text-public"> public, left</span> &nbsp;·&nbsp; <span class="text-private">private, right</span> —
    solid where it's built, dotted downward where it keeps growing, infinitely.
  </figcaption>
</figure>
