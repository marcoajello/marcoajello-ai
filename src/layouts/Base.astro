---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "alter/me/a/i — own your data, decide what flows where",
  description = "alter/me/a/i is a free, open-source suite of lightweight data-filtering browser extensions that feed your Vault — a local-first, encrypted store you fully own. Together they form the backbone of a complete personal data-aggregation system. The cortex is the engine in the middle.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://marcoajello.ai" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
